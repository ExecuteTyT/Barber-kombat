# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/barber_kombat

# Redis
REDIS_URL=redis://localhost:6379/0

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_MINI_APP_URL=https://your-domain.com

# YClients
YCLIENTS_API_KEY=your_api_key
YCLIENTS_BEARER_TOKEN=your_bearer_token
YCLIENTS_COMPANY_ID=your_company_id
YCLIENTS_WEBHOOK_SECRET=your_webhook_secret

# WhatsApp (optional)
WHATSAPP_API_URL=https://api.green-api.com
WHATSAPP_API_TOKEN=your_token
WHATSAPP_INSTANCE_ID=your_instance

# JWT
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# App
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
